# Genera uno con: npx auth secret
AUTH_SECRET=

# URL pública de la app (producción). En local suele inferirse. Necesaria para enlaces en emails de recuperación de contraseña.
# AUTH_URL=https://pulse.excelso.xyz

# --- Recuperación de contraseña (Nodemailer / SMTP) ---
# Sin SMTP_HOST + EMAIL_FROM no se envía; en `npm run dev` la respuesta JSON puede incluir `debugResetUrl`.
# Ejemplo Gmail (mejor usar contraseña de aplicación): SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=... SMTP_PASS=...
# Puerto 465 suele requerir SMTP_SECURE=1
# EMAIL_FROM="Excelso Pulse <tu@dominio.com>"
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=0
# Si el envío falla, mira la terminal del servidor (mensaje del servidor SMTP).
# Ocultar el enlace de depuración en local: PASSWORD_RESET_DEV_LINK=0

# MongoDB (usuarios y proyectos)
MONGODB_URI=

# Cifrado de tokens Bearer guardados en MongoDB (64 hex = 32 bytes). Ej.: openssl rand -hex 32
PULSE_SECRETS_MASTER_KEY=

# --- Agregador Pulse (opcional; ver docs/pulse-aggregator.md) ---
# PULSE_FETCH_TIMEOUT_MS=5000
# PULSE_ROUND_TIMEOUT_MS=12000
# PULSE_CACHE_TTL_MS=15000
# PULSE_RATE_LIMIT_MAX=60
# PULSE_RATE_LIMIT_WINDOW_MS=60000
# PULSE_MAX_CONCURRENCY=8
# PULSE_MERGE_ENV_SOURCES=0
# PULSE_SOURCES=[{"id":"demo","pulseUrl":"https://api.example.com/internal/pulse","secretEnvKey":"DEMO_PULSE_TOKEN"}]

# --- Webhook voz / Dialogflow ES (opcional; ver docs/voice-fulfillment.md) ---
# VOICE_WEBHOOK_SECRET=  # opcional: fallback legacy single-user
# VOICE_WEBHOOK_ALT_HEADER_NAME=x-monitoring-token
# VOICE_DEFAULT_USER_EMAIL=tu@correo.com  # opcional: usado solo con fallback legacy
# VOICE_PULSE_CACHE_TTL_MS=45000
# VOICE_PULSE_ROUND_TIMEOUT_MS=9000
# VOICE_PULSE_FETCH_TIMEOUT_MS=4000
