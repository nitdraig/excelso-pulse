# IP/red del proxy de Dokploy que reenvia a Home Assistant.
# Si no conoces la IP exacta, puedes usar un rango (ej: 172.16.0.0/12).
reverse_proxy_ip: 172.16.0.0/12
pulse_webhook_url: "https://pulse.excelso.xyz/api/integrations/home-assistant"
pulse_webhook_authorization: "Bearer CAMBIAR_POR_TOKEN_REAL"
