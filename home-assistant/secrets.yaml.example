# Solo necesario cuando activás el webhook Pulse:
# 1) Copiá rest_commands.yaml.example → rest_commands.yaml (o fusioná el contenido).
# 2) Creá /config/secrets.yaml EN EL VOLUMEN DE LA VPS con estos valores (no va en git).
pulse_webhook_url: "https://pulse.excelso.xyz/api/integrations/home-assistant"
pulse_webhook_authorization: "Bearer CAMBIAR_POR_TOKEN_REAL"
